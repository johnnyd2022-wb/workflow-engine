[app]
environment = test
debug = true
host = host.docker.internal
port = 5001

[database]
host = host.docker.internal
port = 5401
name = workflow-engine
user = postgres
password = YOUR_PASSWORD_HERE
use_keepass = false

[xero]
client_id = YOUR_TEST_XERO_CLIENT_ID
client_secret = YOUR_TEST_XERO_CLIENT_SECRET

[email]
sender_email = your-email@example.com
receiver_email = your-email@example.com

[features]
invoice_button_enabled = false
schedule_enabled = false
crm_enabled = true
workflow_engine_enabled = true

[observability]
log_level = INFO
log_format = json
otel_enabled = false
otel_service_name = workflow-engine
otel_sample_rate = 0.0
otel_exporter_endpoint = http://localhost:4317
otel_exporter_protocol = grpc
otel_capture_metrics = false
rum_enabled = false
rum_collector_url = /telemetry
rum_sample_rate = 0.0
rum_mask_inputs = true
rum_faro_upstream = http://localhost:12347
rum_posthog_upstream = http://localhost:8000
rum_posthog_api_key =
