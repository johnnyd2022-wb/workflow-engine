[app]
environment = test
debug = true
host = host.docker.internal
port = 5001

[database]
host = host.docker.internal
port = 5401
name = workflow-engine
user = postgres
password = YOUR_PASSWORD_HERE
use_keepass = false

[xero]
client_id = YOUR_TEST_XERO_CLIENT_ID
client_secret = YOUR_TEST_XERO_CLIENT_SECRET

[email]
sender_email = your-email@example.com
receiver_email = your-email@example.com

[features]
invoice_button_enabled = false
schedule_enabled = false
crm_enabled = true
workflow_engine_enabled = true

[observability]
log_level = INFO
log_format = json
otel_enabled = false
otel_service_name = workflow-engine
otel_sample_rate = 0.0
otel_exporter_endpoint = http://localhost:4317
otel_exporter_protocol = grpc
otel_capture_metrics = false
rum_enabled = true
rum_collector_url = /telemetry
rum_sample_rate = 1.0
rum_mask_inputs = true
# The test app runs in Docker. These names resolve to the local observability
# stack after the test deployment joins the workflow-observability network.
rum_faro_upstream = http://alloy:12347
rum_posthog_upstream = http://posthog-web:8000
rum_posthog_capture_upstream = http://posthog-capture:3000
rum_posthog_replay_upstream = http://posthog-replay-capture:3000
rum_posthog_feature_flags_upstream = http://posthog-feature-flags:3001
rum_posthog_api_key =
keepass_posthog_project_api_key_entry = workflow-engine/observability/posthog_project_api_key
