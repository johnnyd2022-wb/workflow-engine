<!DOCTYPE html>
<html>
<head>
    <title>Top buyers</title>
    <!-- Add a link to the CSS file -->
    <link rel="stylesheet" href="{{ url_for('static', filename='styles_raw_data.css') }}">
</head>
<body>
    <div class="container">
        <h1>Top buyers - weekly rate</h1>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Buyer</th>
                    <th>{{ current_month_name }}</th>
                    <th>{{ last_month_name }}</th>
                    <th>{{ two_months_ago_name }}</th>
                </tr>
            </thead>
            <tbody>
                {% for buyer, current_month_weekly_rate, last_month_weekly_rate, two_months_ago_weekly_rate in weekly_rate_summary %}
		    <tr{% if buyer == 'Total' %} style="font-weight: bold;" {% endif %}>
		        <td>{{ buyer }}</td>
                        <td>{{ current_month_weekly_rate }}</td>
                        <td>{{ last_month_weekly_rate }}</td>
                        <td>{{ two_months_ago_weekly_rate }}</td>
		    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="container">
        <h1>Sales - Past 3 months</h1>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Buyer</th>
		    <th>{{ current_month_name }}</th>
		    <th>{{ last_month_name }}</th>
		    <th>{{ two_months_ago_name }}</th>
                </tr>
            </thead>
            <tbody>
                {% for buyer, current_month, last_month, two_months_ago in three_month_totals %}
                    <tr {% if buyer == 'Total' %} style="font-weight: bold;" {% endif %}>
                        <td>{{ buyer }}</td>
                        <td>{{ current_month }}</td>
			<td>{{ last_month }}</td>
			<td>{{ two_months_ago }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="container">
        <h1>Sales - All time</h1>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Buyer</th>
                    <th>Total bottles sold</th>
                    <th>Percentage of total sales</th>
		    <th>Overall rate of bottles sold (Per week)</th>
		    <th>Weeks since first order</td>
                </tr>
            </thead>
            <tbody>
		{% for buyer, total_bottles_sold, percentage_of_total, overall_rate_per_week, total_weeks_since_first_order in top_buyers %}
                    <tr {% if buyer == 'Total' %} style="font-weight: bold;" {% endif %}>
                        <td>{{ buyer }}</td>
                        <td>{{ total_bottles_sold }}</td>
			<td>{{ "%.2f"|format(percentage_of_total) if percentage_of_total is not none else '-' }}</td>
                        <td>{{ "%.2f"|format(overall_rate_per_week) if overall_rate_per_week is not none else '-' }}</td>
                        <td>{{ "%.0f"|format(total_weeks_since_first_order) if total_weeks_since_first_order is not none else '-' }}</td>
                    </tr>
		{% endfor %}
            </tbody>
        </table>
    </div>

    <div class="button-container">
        <form action="/back-button-data-tools" method="post" class="form">
            <button type="submit" class="top-right-button">Back to Data tools</button>
        </form>

    </div>

</body>
</html>
