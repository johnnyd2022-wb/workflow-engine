@app.route('/download-csv', methods=['POST'])			@app.route('/download-csv', methods=['POST'])
def download_csv():						def download_csv():
    from initialize import db_conn				    from initialize import db_conn
    import pandas as pd						    import pandas as pd
    from flask import Flask, render_template, Response, send_	    from flask import Flask, render_template, Response, send_
    import io							    import io
    import zipfile						    import zipfile
    connection, cursor = db_conn()				    connection, cursor = db_conn()

    # Get a list of all tables in the public schema		    # Get a list of all tables in the public schema
    cursor.execute("""						    cursor.execute("""
        SELECT table_name					        SELECT table_name
        FROM information_schema.tables				        FROM information_schema.tables
        WHERE table_schema = 'public'				        WHERE table_schema = 'public'
        AND table_type = 'BASE TABLE'				        AND table_type = 'BASE TABLE'
        AND table_name NOT IN ('actions', 'audit')  -- Exclud	        AND table_name NOT IN ('actions', 'audit')  -- Exclud
    """)							    """)
    tables = cursor.fetchall()					    tables = cursor.fetchall()

    # Create a list to hold queries for each table		    # Create a list to hold queries for each table
    queries = []						    queries = []

    # Generate a query for each table				    # Generate a query for each table
    for table in tables:					    for table in tables:
        table_name = table[0]					        table_name = table[0]
        query = f"SELECT * FROM {table_name}"			        query = f"SELECT * FROM {table_name}"
        queries.append({"name": table_name, "query": query})	        queries.append({"name": table_name, "query": query})

    # Create a zip file in memory				    # Create a zip file in memory
    zip_buffer = io.BytesIO()					    zip_buffer = io.BytesIO()
    with zipfile.ZipFile(zip_buffer, 'w') as zipf:		    with zipfile.ZipFile(zip_buffer, 'w') as zipf:
        for query_info in queries:				        for query_info in queries:
            query_name = query_info["name"]			            query_name = query_info["name"]
            query = query_info["query"]				            query = query_info["query"]

            df = pd.read_sql_query(query, connection)		            df = pd.read_sql_query(query, connection)
            csv_data = df.to_csv(index=False)			            csv_data = df.to_csv(index=False)

            # Add CSV data to the zip file			            # Add CSV data to the zip file
            zipf.writestr(f'{query_name}.csv', csv_data)	            zipf.writestr(f'{query_name}.csv', csv_data)

    # Create a Flask response with the zip file			    # Create a Flask response with the zip file
    zip_buffer.seek(0)						    zip_buffer.seek(0)
    response = send_file(					    response = send_file(
        zip_buffer,						        zip_buffer,
        mimetype='application/zip',				        mimetype='application/zip',
        as_attachment=True,					        as_attachment=True,
        download_name='data.zip'				        download_name='data.zip'
    )								    )
    connection.close()						    connection.close()
    return response						    return response

