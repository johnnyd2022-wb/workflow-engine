# Reference settings for non-KeePassXC deployments.
#
# Local development should use `uv run workflow observability start`, which
# reads required values from KeePassXC rather than sourcing this file. Do not
# copy this file for the local workflow.

# Public URL used by PostHog itself.
POSTHOG_SITE_URL=http://localhost:8000

# Required: Django secret key used by PostHog web/worker services.
# Generate with: openssl rand -hex 32
POSTHOG_SECRET=replace-with-random-secret

# Required by plugin-server encryption routines.
# Keep this stable for a given PostHog environment.
# Generate with: openssl rand -hex 32
ENCRYPTION_SALT_KEYS=replace-with-random-salt-key
